# Database Configuration (External PostgreSQL for Production)
DATABASE_URL=postgresql+asyncpg://username:password@hostname:5432/database_name

# AI Service API Keys
OPENAI_API_KEY=your_openai_api_key_here

# Voyage AI for embeddings (optional - only needed if EMBEDDING_PROVIDER=voyage)
VOYAGE_API_KEY=your_voyage_api_key_here

# Embedding provider: "openai" (default) or "voyage"
# openai: Uses text-embedding-3-small (1536 dims) -> data_llamaindex_embeddings
# voyage: Uses voyage-3.5-lite (512 dims) -> data_llamalite_embeddings
EMBEDDING_PROVIDER=openai

# Email Service (for OTP verification)
RESEND_API_KEY=your_resend_api_key_here

# API Authentication
MYCLONE_API_KEY=your_secure_api_key_here
MYCLONE_REQUIRE_API_KEY=true  # Set to false to disable API key requirement

# Application Settings
HOST_PORT=8001  # Port for the backend service
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
PROJECT_NAME=MyClone

# Monitoring & Error Tracking (Optional)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# ENVIRONMENT=development  # Options: development, staging, production
# GIT_SHA=main  # Set this in CI/CD to track releases

# Vector Database Settings
# 1536 for OpenAI text-embedding-3-small (default)
# 512 for Voyage AI 3.5 lite (if EMBEDDING_PROVIDER=voyage)
VECTOR_DIMENSION=1536
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# LiveKit Cloud Configuration
LIVEKIT_URL=wss://your-livekit-instance.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_AGENT_NAME=expert_agent
LIVEKIT_AGENT_VERSION=modular

# Langfuse Configuration (for LLM observability and tracing)
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# Voice Service API Keys (Required for LiveKit Voice Integration)
DEEPGRAM_API_KEY=your_deepgram_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_DEFAULT_VOICE_ID=your_elevenlabs_voice_id_here

# Cartesia Voice Configuration
CARTESIA_API_KEY=your_cartesia_api_key_here
CARTESIA_DEFAULT_VOICE_ID=your_cartesia_voice_id_here

# Development Only (not used in production)
# POSTGRES_USER=persona_user
# POSTGRES_PASSWORD=change_this_password
# POSTGRES_DB=persona_db
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
# REDIS_HOST=redis
# REDIS_PORT=6379

# API Base URL (your backend's public URL)
API_BASE_URL=http://localhost:8001/api/v1

ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

NATS_URL=nats://localhost:4223

# LinkedIn OAuth Configuration
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here

# Firecrawl (for URL content fetching in RAG queries)
# FIRECRAWL_API_KEY=your_firecrawl_api_key_here
# FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v1

# Brave Search API (for internet search in LiveKit agent)
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
# COOKIE_DOMAIN=.yourdomain.com  # Set in production for cross-subdomain cookies

# CORS Origins (comma-separated, in addition to localhost defaults)
# CORS_ORIGINS=https://app.yourdomain.com,https://yourdomain.com

# JWT Configuration
JWT_SECRET_KEY=your_jwt_secret_key_here  # Generate with: openssl rand -base64 32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DAYS=30

# Encryption Configuration (for OAuth tokens)
ENCRYPTION_KEY=your_encryption_key_here  # Generate with: openssl rand -base64 32

# Resend Email Configuration (for onboarding emails)
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=Your Name <noreply@yourdomain.com>  # Must be a verified domain
SUPPORT_EMAIL=support@yourdomain.com

# Get your Marker.io API key from: https://www.datalab.to/
DATALAB_API_KEY=your_datalab_api_key_here

# AWS S3 Configuration (for avatar uploads and user data)
USER_DATA_BUCKET=myclone-user-data
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here

# For local development with LocalStack
# AWS_ENDPOINT_URL=http://localstack:4566

# YouTube Proxy (for bypassing IP-based bot detection)
# Format: http://username:password@proxy.example.com:port
# YOUTUBE_PROXY_URL=

# Webshare Proxy (for YouTube transcript fetching)
WEBSHARE_PROXY_USERNAME=your_webshare_username_here
WEBSHARE_PROXY_PASSWORD=your_webshare_password_here

# Password Security Configuration
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=false
BCRYPT_ROUNDS=12

# Account Security Configuration
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=15

# Email Verification Configuration
EMAIL_VERIFICATION_TOKEN_EXPIRY_HOURS=24

# Password Reset Configuration
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=1

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Vercel Domain Integration (for custom domain white-labeling)
VERCEL_API_TOKEN=your_vercel_api_token_here
VERCEL_PROJECT_ID=your_vercel_project_id_here
VERCEL_TEAM_ID=your_vercel_team_id_here

# LiveKit S3 uploader (for voice recording egress)
AWS_LIVEKIT_EGRESS_ACCESS_KEY_ID=your_access_key_id
AWS_LIVEKIT_EGRESS_SECRET_ACCESS_KEY=your_secret_access_key

# Slack Notifications (Optional)
# SLACK_WEBHOOK_URL=your_slack_webhook_url
