# ===========================================
# MyClone Frontend Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# API Configuration (required)
NEXT_PUBLIC_API_URL=http://localhost:8001/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Website URL (for pricing links, docs links, etc.)
# NEXT_PUBLIC_WEBSITE_URL=https://myclone.is

# Support email (shown in contact forms, error pages)
# NEXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com

# Platform domains (comma-separated, for custom domain detection)
# NEXT_PUBLIC_PLATFORM_DOMAINS=myclone.is,app.myclone.is

# Landing Page URL (optional)
NEXT_PUBLIC_LANDING_PAGE_URL=

# API Key (optional)
NEXT_PUBLIC_API_KEY=

# LiveKit - Real-time voice chat (optional)
NEXT_PUBLIC_LIVEKIT_URL=

# Sentry - Error monitoring (optional)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# PostHog - Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Google Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Slack - Error notifications (optional, server-side)
SLACK_WEBHOOK_URL=

# Skip env validation during build (optional)
# SKIP_ENV_VALIDATION=true
